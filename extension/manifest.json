{
  "manifest_version": 3,
  "name": "Autoplay Media Killer",
  "short_name": "AutoplayKiller",
  "description": "Detect and block autoplay media across websites with granular controls and synced whitelists.",
  "version": "1.0.0",
  "permissions": ["storage", "tabs", "activeTab", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Autoplay Media Killer",
    "default_popup": "popup/index.html"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
